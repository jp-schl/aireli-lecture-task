onId":"c846a03e-1bf5-4471-a56a-8763ab838eec1773683913441","machineId":"c4d126563e4cec0031eb623cc3e1ccca841b780c75b995bf9013602ee90573cc","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"supreme-waffle-x5pv54pq7pxj396g9","eventName":"DocumentChangeEvent","eventTime":1773685893447,"sessionId":"c846a03e-1bf5-4471-a56a-8763ab838eec1773683913441","machineId":"c4d126563e4cec0031eb623cc3e1ccca841b780c75b995bf9013602ee90573cc","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":11,"operation":"replace","value":"export const registerUser = async (req: Request, res: Response): Promise<void> => {\n  try {\n    const { email, password } = req.body;\n\n    // Validate input\n    if (!email || !password) {\n      res.status(400).json({ error: \"Email and password are required.\" });\n      return;\n    }\n\n    // Create the user in the database\n    const newUser = await createUser(email, password);\n\n    // Generate a JWT token (optional, for immediate login)\n    const token = jwt.sign(\n      { id: newUser.id, email: newUser.email },\n      process.env.JWT_SECRET || 'default_secret', // make sure to set JWT_SECRET in your environment\n      { expiresIn: '1h' }\n    );\n\n    // Send success response\n    res.status(201).json({\n      message: \"User registered successfully\",\n      user: { id: newUser.id, email: newUser.email },\n      token\n    });\n  } catch (error: any) {\n    console.error(\"Error registering user:\", error);\n    res.status(500).json({ error: \"Internal server error\" });\n  }\n};","rangeOffset":"194","rangeLength":"238","rangestart_line":"5","rangestart_character":"0","rangeend_line":"15","rangeend_character":"2"},{"codespaceName":"supreme-waffle-x5pv54pq7pxj396g9","eventName":"DocumentSaveEvent","eventTime":1773685895019,"sessionId"