lients/internalClient.ts","documentId":12,"operation":"replace","value":"const loginUser = async (input: PlatformUserCreateInput) => {\n  try {\n    // 1️⃣ Send credentials to backend\n    const { data } = await axios.post(\"http://localhost:3001/auth/login\", {\n      email: input.email,\n      password: input.password,\n    });\n\n    // data should be: { user: { id, email }, accessToken, expiresAt }\n    const user = data.user;\n\n    // 2️⃣ Generate JWT token for frontend if needed\n    const accessToken = jwt.sign(\n      { id: user.id },\n      process.env.JWT_SECRET || \"no_key_set\",\n      { expiresIn: \"1h\" }\n    );\n    const expiresAt = new Date(Date.now() + 3600 * 1000).toISOString();\n\n    return { accessToken, expiresAt };\n  } catch (error) {\n    console.error(\"Login failed:\", error);\n    return null;\n  }\n};","rangeOffset":"662","rangeLength":"729","rangestart_line":"20","rangestart_character":"0","rangeend_line":"35","rangeend_character":"2"},{"codespaceName":"supreme-waffle-x5pv54pq7pxj396g9","eventName":"DocumentSaveEvent","eventTime":1773687106401,"sessionId":"c846a03e-1bf5-4471-a56a-8763ab838eec1773683913441","machineId":"c4d126563e4cec0031eb623cc3e1ccca841b780c75b995bf9013602ee90573cc","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":12,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"supreme-waffle-x5pv54pq7pxj396g9","eventName":"ActiveEditorChangeEvent","eventTime":1773687117530,"sessionId":"c846a03e-1bf5-4471-a56a-8763ab838eec1773683913441","machineId":"c4d126563e4cec0031eb623cc3e1ccca841b780c75b995bf9013602ee90573cc","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/app/actions/user.actions.ts","documentId":14,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_charac